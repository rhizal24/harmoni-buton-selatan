# Server
PORT=3001

# Neon Postgres connection string (from the Neon dashboard -> Connection Details)
# e.g. postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Seed credentials for the two village admins (used by `npm run seed`)
ADMIN_GAYABARU_USERNAME=admin_gayabaru
ADMIN_GAYABARU_PASSWORD=
ADMIN_GERAKMAKMUR_USERNAME=admin_gerakmakmur
ADMIN_GERAKMAKMUR_PASSWORD=

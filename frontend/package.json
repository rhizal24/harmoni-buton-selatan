{
  "name": "harmoni-buton-selatan-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo frontend website desa — Buton Selatan",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "dev:gayabaru": "pnpm --filter desagayabaru dev",
    "dev:gerakmakmur": "pnpm --filter desagerakmakmur dev",
    "build": "pnpm --filter './apps/*' build",
    "build:gayabaru": "pnpm --filter desagayabaru build",
    "build:gerakmakmur": "pnpm --filter desagerakmakmur build",
    "lint": "pnpm --filter './apps/*' lint",
    "type-check": "pnpm --filter './apps/*' type-check"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0"
}

# Environment variables — Desa Gerak Makmur
# Salin ke .env.local dan isi nilainya (jangan commit .env.local!)

NEXT_PUBLIC_SITE_URL=https://desagerakmakmur.butonselatan.com

# --- Backend API (Express + Postgres di `backend/`) ---
# Fetch data publik dilakukan di server → pakai API_URL (server-only) sebagai
# sumber utama; NEXT_PUBLIC_API_URL hanya fallback bila perlu dari client.
#
# PENTING: app ini dev di :3001 (lihat package.json), sama dengan default backend.
# Jalankan backend di port lain, mis. `PORT=4000 npm run dev`, lalu samakan di sini.
API_URL=http://localhost:4000/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_DESA_NAME=Desa Gerak Makmur
NEXT_PUBLIC_DESA_EMAIL=info@desagerakmakmur.butonselatan.com
NEXT_PUBLIC_DESA_PHONE=+62-xxx-xxxx-xxxx
NEXT_PUBLIC_DESA_ADDRESS=Desa Gerak Makmur, Buton Selatan, Sulawesi Tenggara
